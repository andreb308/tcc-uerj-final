generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Report {
  id             String       @id @default(cuid())
  status         ReportStatus @default(pending)
  artist         String
  trackTitle     String
  targetLanguage String
  artifactData   String       @db.Text
  reportData     Json?
  createdAt      DateTime     @default(now())

  @@map("reports")
}

enum ReportStatus {
  pending
  generating
  complete
  error
}
